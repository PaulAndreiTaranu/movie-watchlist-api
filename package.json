{
    "name": "movie-watchlist-api",
    "version": "1.0.0",
    "description": "",
    "main": "src/server.ts",
    "scripts": {
        "with-local-env": "dotenvx run -f .env.local --",
        "build": "pnpm with-local-env tsc",
        "start": "node dist/index.js",
        "dev": "pnpm with-local-env tsx --watch src/server.ts",
        "test": "pnpm with-local-env vitest --run",
        "test:watch": "pnpm with-local-env vitest",
        "prisma:gen": "pnpm with-local-env prisma generate",
        "prisma:migrate": "pnpm with-local-env prisma migrate dev",
        "prisma:studio": "pnpm with-local-env prisma studio",
        "prisma:reset": "pnpm with-local-env prisma migrate reset --force",
        "prisma:seed": "pnpm with-local-env prisma db seed"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "packageManager": "pnpm@10.20.0",
    "dependencies": {
        "@dotenvx/dotenvx": "^1.52.0",
        "@prisma/adapter-pg": "^7.4.1",
        "@prisma/client": "^7.4.1",
        "express": "^5.2.1",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/express": "^5.0.6",
        "@types/node": "^25.3.0",
        "@types/supertest": "^6.0.3",
        "prisma": "^7.4.1",
        "supertest": "^7.2.2",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "vitest": "^4.0.18"
    }
}
